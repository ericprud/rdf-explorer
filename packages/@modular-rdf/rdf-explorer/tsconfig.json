{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@modular-rdf/graph-source-api":  ["../graph-source-api/src/graph-source-api.ts"],
      "@modular-rdf/graph-handler-api": ["../graph-handler-api/src/graph-handler-api.ts"],
      "@modular-rdf/rdf-utils":         ["../rdf-utils/src/rdf-utils.ts"],
      "@modular-rdf/pane-sparql":       ["../pane-sparql/src/pane-sparql.ts"],
      "@modular-rdf/pane-inference":    ["../pane-inference/src/pane-inference.ts"],
      "@modular-rdf/pane-graph":        ["../pane-graph/src/pane-graph.ts"],
      "@modular-rdf/pane-turtle":       ["../pane-turtle/src/pane-turtle.ts"],
      "@modular-rdf/pane-shex":         ["../pane-shex/src/pane-shex.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
