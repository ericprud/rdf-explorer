{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@modular-rdf/api-graph-source":  ["../api-graph-source/src/api-graph-source.ts"],
      "@modular-rdf/api-graph-handler": ["../api-graph-handler/src/api-graph-handler.ts"],
      "@modular-rdf/util-rdf":         ["../util-rdf/src/util-rdf.ts"],
      "@modular-rdf/pane-sparql":       ["../pane-sparql/src/pane-sparql.ts"],
      "@modular-rdf/pane-inference":    ["../pane-inference/src/pane-inference.ts"],
      "@modular-rdf/pane-graph":        ["../pane-graph/src/pane-graph.ts"],
      "@modular-rdf/pane-turtle":       ["../pane-turtle/src/pane-turtle.ts"],
      "@modular-rdf/pane-shex":         ["../pane-shex/src/pane-shex.ts"],
      "@modular-rdf/pane-diff":         ["../pane-diff/src/pane-diff.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
