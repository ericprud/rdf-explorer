{
  "name": "modular-rdf-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/@modular-rdf/*"
  ],
  "scripts": {
    "dev":           "npm run dev        -w @modular-rdf/rdf-explorer",
    "build":         "npm run build      -w @modular-rdf/rdf-explorer",
    "build:loaders": "npm run build:loaders -w @modular-rdf/rdf-explorer",
    "preview":       "npm run preview    -w @modular-rdf/rdf-explorer",
    "type-check":    "npm run type-check -w @modular-rdf/rdf-explorer",
    "test":          "npm run test       -w @modular-rdf/rdf-explorer",
    "test:watch":    "npm run test:watch -w @modular-rdf/rdf-explorer"
  }
}
