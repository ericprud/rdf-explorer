{
  "name": "rdf-explorer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/build-loaders.mjs --watch & vite",
    "build:loaders": "node scripts/build-loaders.mjs",
    "build": "node scripts/build-loaders.mjs && vite build",
    "type-check": "tsc --noEmit --skipLibCheck",
